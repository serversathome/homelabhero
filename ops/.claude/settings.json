{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(hh list)",
      "Bash(hh list:*)",
      "Bash(hh overview)",
      "Bash(hh inventory)",
      "Bash(hh inventory:*)",
      "Bash(hh test:*)",
      "Bash(hh scan)",
      "Bash(hh scan:*)",
      "Bash(hh doctor)",
      "Bash(hh diff)",
      "Bash(hh diff:*)",
      "Bash(hh version)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ping:*)",
      "Bash(dig:*)",
      "Bash(nc:*)"
    ],
    "deny": [
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(sudo:*)",
      "Bash(hh update)",
      "Bash(hh add-host:*)",
      "Bash(hh rm-host:*)",
      "Bash(hh scan --add)",
      "Bash(hh scan --add:*)",
      "Bash(hh audit)",
      "Bash(hh audit:*)",
      "Bash(cat /etc/homelabhero/vault/*)",
      "Read(/etc/homelabhero/vault/**)",
      "Read(~/.ssh/id_*)",
      "Bash(rm -rf:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(wipefs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot)",
      "Bash(halt)"
    ]
  }
}
