#!/usr/bin/env bash
#
# hh-upgrade - bring HomelabHero itself up to date: pull the latest release and
# re-run the installer non-interactively, in place. This is the single upgrade
# path - it produces exactly what a fresh install does (CLI, broker, skills,
# CLAUDE.md, capabilities, Node/npm at latest LTS, the systemd unit), because it
# literally re-runs setup/main.sh with HH_NONINTERACTIVE=1 (skipping only the
# interactive sign-in and add-servers steps). The installer is idempotent and
# keeps your users, credentials, registered hosts, and ops notes.
#
# Run by `hh upgrade` and by the weekly cron. Node/npm updates happen HERE (via
# the installer), not in hh-update, which does OS packages only. Runs as root.
# No `set -e`: a hiccup must not leave the box half-done without a clear message.
#
set -uo pipefail

CFG_DIR="/etc/homelabhero"
INSTALL_CONF="${CFG_DIR}/install.conf"

log()  { printf '%s\n' "$*"; }
warn() { printf '[warn] %s\n' "$*" >&2; }

echo "--- HomelabHero self-update (code, skills, Node/npm)"

[ "$(id -u)" -eq 0 ] || { warn "hh-upgrade must run as root; skipping."; exit 0; }

conf_get() { awk -F= -v k="$2" '$1==k{sub(/^[^=]*=/,"");gsub(/^[ "]+|[ "]+$/,"");print;exit}' "$1"; }

if [ ! -f "$INSTALL_CONF" ]; then
  warn "no ${INSTALL_CONF} (this install predates self-update)."
  warn "re-run the installer once to enable automatic updates."
  exit 0
fi

CHECKOUT="$(conf_get "$INSTALL_CONF" CHECKOUT)"
BRANCH="$(conf_get "$INSTALL_CONF" BRANCH)"; [ -n "$BRANCH" ] || BRANCH="main"
REPO="$(conf_get "$INSTALL_CONF" REPO)"

[ -n "$CHECKOUT" ] || { warn "install.conf has no CHECKOUT; skipping."; exit 0; }
command -v git >/dev/null 2>&1 || { warn "git not installed; skipping."; exit 0; }

# Make sure the source checkout is present. If it was deleted, re-clone it.
if [ ! -d "$CHECKOUT/.git" ]; then
  [ -n "$REPO" ] || { warn "checkout ${CHECKOUT} is missing and no REPO recorded; skipping."; exit 0; }
  log "Checkout ${CHECKOUT} missing; re-cloning ${REPO} (${BRANCH})."
  rm -rf "$CHECKOUT"
  git clone --depth 1 --branch "$BRANCH" "$REPO" "$CHECKOUT" >/dev/null 2>&1 \
    || { warn "clone failed (offline?); skipping."; exit 0; }
fi

OLD_HEAD="$(git -C "$CHECKOUT" rev-parse HEAD 2>/dev/null || echo none)"
git -C "$CHECKOUT" fetch --depth 1 origin "$BRANCH" >/dev/null 2>&1 \
  || { warn "git fetch failed (offline?); keeping the current version."; exit 0; }
git -C "$CHECKOUT" reset --hard "origin/${BRANCH}" >/dev/null 2>&1 \
  || { warn "git reset failed; keeping the current version."; exit 0; }
NEW_HEAD="$(git -C "$CHECKOUT" rev-parse HEAD 2>/dev/null || echo none)"

if [ "$OLD_HEAD" = "$NEW_HEAD" ]; then
  log "Code already current (${NEW_HEAD:0:7}); re-running the installer to keep Node/deps at latest LTS."
else
  log "Updated ${OLD_HEAD:0:7} -> ${NEW_HEAD:0:7}; re-running the installer to apply it."
fi

# Re-run the installer non-interactively. It does everything: binaries, templates,
# the ops-brain refresh (shipped files overwritten, user notes preserved), Node at
# latest LTS, npm packages with the correct --allow-scripts set, and the systemd
# unit. HH_NONINTERACTIVE=1 skips only sign-in and add-servers.
if [ ! -f "$CHECKOUT/setup/main.sh" ]; then
  warn "installer not found at ${CHECKOUT}/setup/main.sh; cannot upgrade."
  exit 1
fi
HH_NONINTERACTIVE=1 bash "$CHECKOUT/setup/main.sh"
rc=$?
if [ "$rc" -ne 0 ]; then
  warn "installer exited ${rc}; the box may be partially updated - check the log above."
  exit "$rc"
fi
log "Self-update complete."
