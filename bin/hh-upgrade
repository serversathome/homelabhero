#!/usr/bin/env bash
#
# hh-upgrade - pull the latest HomelabHero from git and refresh the installed
# pieces IN PLACE, without re-running the full installer. It runs as the first
# step of hh-update (so the weekly cron and `hh update` both self-update), and
# directly from `hh upgrade`. Runs as root.
#
# It only overwrites HomelabHero-OWNED files: the CLI binaries, the shipped
# skills / CLAUDE.md / capabilities, and the security/log templates. It never
# touches user-owned content - environment notes under infra/, inventory/,
# runbooks/, hosts/, the cron schedule, or cloudcli.env. See README "Staying
# up to date". Deliberately no `set -e`: a hiccup in one step must not abort the
# hh-update run that called us.
#
set -uo pipefail

CFG_DIR="/etc/homelabhero"
INSTALL_CONF="${CFG_DIR}/install.conf"
AGENT_USER="hhagent"

log()  { printf '%s\n' "$*"; }
warn() { printf '[warn] %s\n' "$*" >&2; }

echo "--- HomelabHero self-update (code + skills)"

[ "$(id -u)" -eq 0 ] || { warn "hh-upgrade must run as root; skipping."; exit 0; }

conf_get() { awk -F= -v k="$2" '$1==k{sub(/^[^=]*=/,"");gsub(/^[ "]+|[ "]+$/,"");print;exit}' "$1"; }

if [ ! -f "$INSTALL_CONF" ]; then
  warn "no ${INSTALL_CONF} (this install predates self-update)."
  warn "re-run the installer once to enable automatic code updates."
  exit 0
fi

CHECKOUT="$(conf_get "$INSTALL_CONF" CHECKOUT)"
BRANCH="$(conf_get "$INSTALL_CONF" BRANCH)"; [ -n "$BRANCH" ] || BRANCH="main"
REPO="$(conf_get "$INSTALL_CONF" REPO)"

[ -n "$CHECKOUT" ] || { warn "install.conf has no CHECKOUT; skipping code self-update."; exit 0; }
command -v git >/dev/null 2>&1 || { warn "git not installed; skipping code self-update."; exit 0; }

# Make sure the source checkout is present. If it was deleted, re-clone it.
if [ ! -d "$CHECKOUT/.git" ]; then
  [ -n "$REPO" ] || { warn "checkout ${CHECKOUT} is missing and no REPO recorded; skipping."; exit 0; }
  log "Checkout ${CHECKOUT} missing; re-cloning ${REPO} (${BRANCH})."
  rm -rf "$CHECKOUT"
  git clone --depth 1 --branch "$BRANCH" "$REPO" "$CHECKOUT" >/dev/null 2>&1 \
    || { warn "clone failed (offline?); skipping code self-update."; exit 0; }
fi

OLD_HEAD="$(git -C "$CHECKOUT" rev-parse HEAD 2>/dev/null || echo none)"
git -C "$CHECKOUT" fetch --depth 1 origin "$BRANCH" >/dev/null 2>&1 \
  || { warn "git fetch failed (offline?); keeping the current version."; exit 0; }
git -C "$CHECKOUT" reset --hard "origin/${BRANCH}" >/dev/null 2>&1 \
  || { warn "git reset failed; keeping the current version."; exit 0; }
NEW_HEAD="$(git -C "$CHECKOUT" rev-parse HEAD 2>/dev/null || echo none)"

if [ "$OLD_HEAD" = "$NEW_HEAD" ]; then
  log "Already current (${NEW_HEAD:0:7}); nothing to refresh."
  exit 0
fi

log "Updating ${OLD_HEAD:0:7} -> ${NEW_HEAD:0:7}; refreshing installed files."
R="$CHECKOUT"

# --- Binaries (HomelabHero-owned). `install` writes a NEW inode, so replacing
#     hh-update / hh-upgrade while THIS run is still executing them is safe: the
#     running process keeps reading its old inode and the new code takes effect
#     on the next run.
for b in hh hh-connect hh-update hh-provision hh-upgrade; do
  [ -f "$R/bin/$b" ] && install -o root -g root -m 755 "$R/bin/$b" "/usr/local/bin/$b"
done

# --- HomelabHero-owned templates. NOT cron.homelabhero (the user may have
#     edited their schedule) and NOT cloudcli.env (user config).
[ -f "$R/templates/hh.completion" ] && \
  install -o root -g root -m 644 "$R/templates/hh.completion" /etc/bash_completion.d/hh
[ -f "$R/templates/logrotate.homelabhero" ] && \
  install -o root -g root -m 644 "$R/templates/logrotate.homelabhero" /etc/logrotate.d/homelabhero
# sudoers is security-sensitive: validate before installing so a bad template
# can never leave the box with a broken sudoers file.
if [ -f "$R/templates/sudoers.homelabhero" ]; then
  TMP_SUDO="$(mktemp)"; cp "$R/templates/sudoers.homelabhero" "$TMP_SUDO"
  if visudo -cf "$TMP_SUDO" >/dev/null 2>&1; then
    install -o root -g root -m 0440 "$TMP_SUDO" /etc/sudoers.d/homelabhero
  else
    warn "new sudoers template failed validation; keeping the existing one."
  fi
  rm -f "$TMP_SUDO"
fi

# --- Ops brain, split by ownership:
#   * HomelabHero-owned, overwritten in place: .claude/ (skills + settings.json),
#     capabilities/, CLAUDE.md. No `rsync --delete`, so a user's OWN custom skill
#     under .claude/skills/ survives; the tradeoff is a skill we retire upstream
#     lingers as harmless cruft.
#   * User-owned, add-only: everything else (infra/, inventory/, runbooks/,
#     hosts/). --ignore-existing adds any brand-new stubs we ship without ever
#     clobbering the environment notes the user has filled in.
AGENT_HOME="$(getent passwd "$AGENT_USER" | cut -d: -f6)"
OPS_DST="${AGENT_HOME}/homelab-ops"
if [ -n "$AGENT_HOME" ] && [ -d "$OPS_DST" ]; then
  # --checksum, not the default size+mtime quick-check: a content fix that keeps
  # the same byte size (a one-char change, a same-length version bump) must still
  # overwrite. This is the "deliver the fix" path, so compare by content.
  rsync -a --checksum "$R/ops/.claude/"      "$OPS_DST/.claude/"
  rsync -a --checksum "$R/ops/capabilities/" "$OPS_DST/capabilities/"
  install -m 644 "$R/ops/CLAUDE.md" "$OPS_DST/CLAUDE.md"
  # Add-only pass for user-owned trees: never overwrite, just add new stubs.
  rsync -a --ignore-existing "$R/ops/" "$OPS_DST/"
  chown -R "$AGENT_USER:$AGENT_USER" "$OPS_DST"
  # The agent user must still be able to READ its brain. A ZFS/NFSv4 ACL on
  # TrueNAS can deny this even when the mode bits look right.
  if ! sudo -u "$AGENT_USER" test -r "$OPS_DST/CLAUDE.md"; then
    warn "agent '${AGENT_USER}' cannot read ${OPS_DST}/CLAUDE.md after the refresh."
    warn "fix: setfacl -R -m u:${AGENT_USER}:rX '${OPS_DST}'"
  fi
else
  warn "ops brain ${OPS_DST} not found; skipped the ops refresh."
fi

# The systemd unit is generated at install time with node paths resolved then,
# so it is NOT regenerated here. If its template changed upstream, say so; the
# user must re-run the installer to pick it up. Best-effort: only when the old
# commit object is still present (a shallow fetch may have pruned it).
if git -C "$R" cat-file -e "$OLD_HEAD" 2>/dev/null \
   && ! git -C "$R" diff --quiet "$OLD_HEAD" "$NEW_HEAD" -- templates/homelab-cc.service.template 2>/dev/null; then
  warn "the systemd service template changed upstream; re-run the installer to apply it."
fi

log "Self-update complete. Review what changed in the ops brain with:"
log "    git -C ${OPS_DST} diff"
