#!/usr/bin/env bash
#
# hh-provision - register a host with a freshly generated key, safe to invoke
# from the UI (i.e. by the agent). Runs as the vault user via a narrow sudoers
# rule. It handles NO secrets: it generates a keypair in the vault (the private
# half never leaves it) and prints only the PUBLIC key for the user to install
# on the target. Password auth is intentionally not supported here; that stays
# in the shell-only `hh add-host`.
#
# Usage: hh-provision <alias> <host> [port] [platform] [user]
#
# The connect user defaults to root (which needs no sudo on the target). Override
# it with a fifth argument or by passing user@host as the host if you must connect
# as a non-root account.
#
set -euo pipefail

REG_DIR="/etc/homelabhero/hosts.d"
VAULT_DIR="/etc/homelabhero/vault"
NAME_RE='^[A-Za-z0-9._-]+$'
HOST_RE='^[A-Za-z0-9._:-]+$'

die() { printf 'hh-provision: %s\n' "$*" >&2; exit 2; }

[ "$#" -ge 2 ] || die "usage: hh-provision <alias> <host> [port] [platform] [user]"
ALIAS="$1"; HOST="$2"; PORT="${3:-22}"; PLAT="${4:-linux}"; RUSER="${5:-}"

# Convenience: allow user@host in the host argument (ssh-style). It wins over a
# fifth-arg user if both are somehow given.
case "$HOST" in *@*) RUSER="${HOST%@*}"; HOST="${HOST#*@}" ;; esac

# No user specified anywhere: default to root (needs no sudo on the target).
[ -n "$RUSER" ] || RUSER="root"

[[ "$ALIAS" =~ $NAME_RE ]] || die "invalid alias"
[[ "$HOST"  =~ $HOST_RE ]] || die "invalid host"
[[ "$RUSER" =~ $NAME_RE ]] || die "invalid user"
[[ "$PORT"  =~ ^[0-9]+$  ]] || die "invalid port"
case "$PLAT" in linux|truenas|proxmox) : ;; *) die "platform must be linux, truenas, or proxmox" ;; esac
[ -e "${REG_DIR}/${ALIAS}.conf" ] && die "alias '${ALIAS}' already registered"

CRED="${ALIAS}.key"
[ -e "${VAULT_DIR}/${CRED}" ] && die "a credential for '${ALIAS}' already exists"

# Generate the keypair in the vault (runs as vault user, so it lands owned by it).
ssh-keygen -t ed25519 -N '' -q -f "${VAULT_DIR}/${CRED}" -C "homelabhero-${ALIAS}"

# Write the non-secret registry entry.
umask 022
cat > "${REG_DIR}/${ALIAS}.conf" <<EOF
# HomelabHero host registry entry (non-secret)
PLATFORM=${PLAT}
HOST=${HOST}
PORT=${PORT}
USER=${RUSER}
AUTH=key
CRED=${CRED}
EOF

# Record the registration in the same broker audit log (best-effort).
printf '%s\t%s\tPROVISION\t%s@%s:%s (%s)\n' \
  "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$ALIAS" "$RUSER" "$HOST" "$PORT" "$PLAT" \
  >>/var/log/homelabhero-broker.log 2>/dev/null || true

# Emit a clear block: confirmation plus the PUBLIC key to install on the target.
echo "REGISTERED ${ALIAS} (${PLAT}) at ${HOST}:${PORT} as ${RUSER}, key auth."
echo "PUBLIC_KEY_BEGIN"
cat "${VAULT_DIR}/${CRED}.pub"
echo "PUBLIC_KEY_END"
