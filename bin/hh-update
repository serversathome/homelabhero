#!/usr/bin/env bash
#
# hh-update - update the OS packages and run a health check. Run as root (`hh
# update` invokes it via sudo; the weekly cron runs it after hh-upgrade).
#
# Scope is deliberately narrow: OS packages ONLY. HomelabHero itself - the CLI,
# skills, Node/npm, and the service - is updated by hh-upgrade, which re-runs the
# installer. Keeping node/app updates out of `hh update` means a plain `hh update`
# is a quick, low-risk OS patch that never bumps Node or restarts the stack.
# Deliberately no `set -e`: if one step hiccups we still want the rest to run.
#
set -uo pipefail
export DEBIAN_FRONTEND=noninteractive

echo "=================================================="
echo "HomelabHero OS update starting: $(date '+%Y-%m-%d %H:%M:%S %Z')"

echo "--- OS packages"
apt-get update -y
apt-get -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" upgrade
apt-get -y autoremove --purge

echo "--- Health check"
/usr/local/bin/hh doctor || echo "doctor reported problems (see above)"

if [ -f /var/run/reboot-required ]; then
  echo "NOTE: a reboot is required to finish these OS updates. Reboot when convenient."
fi

echo "To update HomelabHero itself (CLI, skills, Node): hh upgrade"
echo "HomelabHero OS update done: $(date '+%Y-%m-%d %H:%M:%S %Z')"
echo "=================================================="
